<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Based on CMake's own default MacOSXBundleInfo.plist.in template (the
  MACOSX_BUNDLE_-prefixed substitutions below are CMake's, filled in from
  the countdownsolver target's matching properties at configure time).
  configure_file() does a dumb text-substitution pass over the whole
  file, comments included - do not wrap a variable-name wildcard in this
  comment in a dollar-brace pair, or configure fails outright ("Invalid
  character" in a variable name), confirmed on a real CI run.
  This has NOT been verified against a real Qt-for-iOS build (no Mac/Xcode
  available here) - reconcile on the first real CI run, in particular
  whether any additional Qt-Quick-for-iOS-specific keys are required
  beyond what's listed here.

  TARGETED_DEVICE_FAMILY (iPhone + iPad) is set via the
  XCODE_ATTRIBUTE_TARGETED_DEVICE_FAMILY target property in
  src/app/CMakeLists.txt, not a plist key.
-->
<plist version="1.0">
<dict>
	<!--
	  Without a launch screen, iOS treats the app as pre-iOS-8 and runs it
	  in a fixed legacy point size (the original iPhone's 320x480), then
	  scales/letterboxes that up to the real screen - entirely at the
	  UIKit level, before the app's own window is ever handed control. On
	  a real device this showed up as black bars and clipped, poorly
	  scaled content in every orientation, on every page, and no amount of
	  QML-side width/height/Screen tweaking touched it, since the cause is
	  upstream of Qt entirely. An empty UILaunchScreen dict is Apple's
	  modern (iOS 14+) plist-only declaration - no storyboard file needed
	  - and is enough to opt back into full native-resolution rendering.
	-->
	<key>UILaunchScreen</key>
	<dict/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
	<key>CFBundleIdentifier</key>
	<string>${MACOSX_BUNDLE_GUI_IDENTIFIER}</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>${MACOSX_BUNDLE_BUNDLE_NAME}</string>
	<!--
	  CFBundleName is what CFBundleDisplayName falls back to if unset, but
	  historically had a ~15-character truncation convention on the home
	  screen - CFBundleDisplayName has no such limit and is what iOS
	  actually prefers there, so set it explicitly rather than relying on
	  the fallback. Both read the same CMake substitution so they can't
	  drift apart.
	-->
	<key>CFBundleDisplayName</key>
	<string>${MACOSX_BUNDLE_BUNDLE_NAME}</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>${MACOSX_BUNDLE_SHORT_VERSION_STRING}</string>
	<key>CFBundleVersion</key>
	<string>${MACOSX_BUNDLE_BUNDLE_VERSION}</string>
	<!--
	  Pairs with XCODE_ATTRIBUTE_ASSETCATALOG_COMPILER_APPICON_NAME "AppIcon"
	  (src/app/CMakeLists.txt) and platform/ios/Assets.xcassets/
	  AppIcon.appiconset - without this key Xcode has no app icon slot to
	  compile the asset catalog into, and falls back to its own blank
	  placeholder icon on the home screen.
	-->
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>${MACOSX_BUNDLE_COPYRIGHT}</string>

	<!--
	  All orientations, iPhone and iPad alike - the QML shell's FormFactor
	  breakpoints (see qml/FormFactor.qml) key off window width/height, not
	  device idiom or orientation, so there's nothing left to restrict here.
	  Dropping the earlier landscape-only lock also removes the reason for
	  UIRequiresFullScreen: that key existed only to stop iPad Split
	  View/Slide Over from placing the app in a portrait-shaped pane despite
	  the orientation keys - now that portrait is fully supported, an
	  arbitrary multitasking pane size is no different from a rotated full
	  screen, and the same width/height-driven layout logic handles it.
	-->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
