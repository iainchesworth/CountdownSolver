{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-msvc-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows (MSVC, Debug)",
      "inherits": [
        "windows-msvc-base",
        "debug"
      ]
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows (MSVC, Release)",
      "inherits": [
        "windows-msvc-base",
        "release"
      ]
    },
    {
      "name": "windows-clang-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows (clang-cl, Debug)",
      "inherits": [
        "windows-clang-base",
        "debug"
      ]
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows (clang-cl, Release)",
      "inherits": [
        "windows-clang-base",
        "release"
      ]
    },
    {
      "name": "linux-gcc-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux (GCC, Debug)",
      "inherits": [
        "linux-gcc-base",
        "debug"
      ]
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux (GCC, Release)",
      "inherits": [
        "linux-gcc-base",
        "release"
      ]
    },
    {
      "name": "linux-gcc-coverage",
      "displayName": "Linux (GCC, Coverage)",
      "inherits": [
        "linux-gcc-base",
        "debug"
      ],
      "cacheVariables": {
        "COUNTDOWN_ENABLE_COVERAGE": "ON",
        "COUNTDOWN_ENABLE_SANITIZERS": "OFF"
      }
    },
    {
      "name": "linux-clang-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux (Clang, Debug)",
      "inherits": [
        "linux-clang-base",
        "debug"
      ]
    },
    {
      "name": "linux-clang-release",
      "displayName": "Linux (Clang, Release)",
      "inherits": [
        "linux-clang-base",
        "release"
      ]
    },
    {
      "name": "macos-clang-base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-clang-debug",
      "displayName": "macOS (AppleClang, Debug)",
      "inherits": [
        "macos-clang-base",
        "debug"
      ]
    },
    {
      "name": "macos-clang-release",
      "displayName": "macOS (AppleClang, Release)",
      "inherits": [
        "macos-clang-base",
        "release"
      ]
    },
    {
      "name": "android-arm64-v8a-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{QT_ANDROID_ROOT}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "QT_HOST_PATH": "$env{QT_HOST_PATH}",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "COUNTDOWN_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-arm64-v8a-debug",
      "displayName": "Android (arm64-v8a, Debug)",
      "inherits": [
        "android-arm64-v8a-base",
        "debug"
      ]
    },
    {
      "name": "android-arm64-v8a-release",
      "displayName": "Android (arm64-v8a, Release)",
      "inherits": [
        "android-arm64-v8a-base",
        "release"
      ]
    },
    {
      "name": "ios-base",
      "hidden": true,
      "generator": "Xcode",
      "toolset": "buildsystem=1",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "toolchainFile": "$env{QT_ROOT_DIR}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "QT_HOST_PATH": "$env{QT_HOST_PATH}",
        "COUNTDOWN_BUILD_TESTS": "OFF",
        "CMAKE_XCODE_ATTRIBUTE_CODE_SIGNING_ALLOWED": "NO",
        "CMAKE_XCODE_ATTRIBUTE_CODE_SIGNING_REQUIRED": "NO",
        "CMAKE_XCODE_ATTRIBUTE_CODE_SIGN_IDENTITY": ""
      }
    },
    {
      "name": "ios-debug",
      "displayName": "iOS (device, Debug)",
      "inherits": [
        "ios-base",
        "debug"
      ]
    },
    {
      "name": "ios-release",
      "displayName": "iOS (device, Release)",
      "inherits": [
        "ios-base",
        "release"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "windows-clang-debug",
      "configurePreset": "windows-clang-debug"
    },
    {
      "name": "windows-clang-release",
      "configurePreset": "windows-clang-release"
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release"
    },
    {
      "name": "linux-gcc-coverage",
      "configurePreset": "linux-gcc-coverage"
    },
    {
      "name": "linux-clang-debug",
      "configurePreset": "linux-clang-debug"
    },
    {
      "name": "linux-clang-release",
      "configurePreset": "linux-clang-release"
    },
    {
      "name": "macos-clang-debug",
      "configurePreset": "macos-clang-debug"
    },
    {
      "name": "macos-clang-release",
      "configurePreset": "macos-clang-release"
    },
    {
      "name": "android-arm64-v8a-debug",
      "configurePreset": "android-arm64-v8a-debug"
    },
    {
      "name": "android-arm64-v8a-release",
      "configurePreset": "android-arm64-v8a-release"
    },
    {
      "name": "ios-debug",
      "configurePreset": "ios-debug"
    },
    {
      "name": "ios-release",
      "configurePreset": "ios-release"
    }
  ],
  "testPresets": [
    {
      "name": "base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "windows-msvc-debug",
      "inherits": "base",
      "configurePreset": "windows-msvc-debug"
    },
    {
      "name": "windows-msvc-release",
      "inherits": "base",
      "configurePreset": "windows-msvc-release"
    },
    {
      "name": "windows-clang-debug",
      "inherits": "base",
      "configurePreset": "windows-clang-debug"
    },
    {
      "name": "windows-clang-release",
      "inherits": "base",
      "configurePreset": "windows-clang-release"
    },
    {
      "name": "linux-gcc-debug",
      "inherits": "base",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc-release",
      "inherits": "base",
      "configurePreset": "linux-gcc-release"
    },
    {
      "name": "linux-gcc-coverage",
      "inherits": "base",
      "configurePreset": "linux-gcc-coverage"
    },
    {
      "name": "linux-clang-debug",
      "inherits": "base",
      "configurePreset": "linux-clang-debug"
    },
    {
      "name": "linux-clang-release",
      "inherits": "base",
      "configurePreset": "linux-clang-release"
    },
    {
      "name": "macos-clang-debug",
      "inherits": "base",
      "configurePreset": "macos-clang-debug"
    },
    {
      "name": "macos-clang-release",
      "inherits": "base",
      "configurePreset": "macos-clang-release"
    }
  ]
}
